<div class="space-y-24 md:space-y-32">
  
  <!-- Hero Section -->
  <section class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
    <!-- Left Column text space -->
    <div class="lg:col-span-7 space-y-6 text-left">
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold tracking-wide uppercase bg-sky-100/60 dark:bg-sky-950/60 text-sky-600 dark:text-sky-300">
        <span class="w-1.5 h-1.5 rounded-full bg-sky-500 animate-pulse"></span>
        Hobbyist Programmer
      </span>
      
      <h1 class="text-5xl lg:text-7xl font-bold tracking-tight text-slate-900 dark:text-slate-100">
        Creating an interesting project
      </h1>
      
      <p class="text-lg md:text-xl text-slate-600 dark:text-slate-400 leading-relaxed font-light">
        <%= config.bio %>
      </p>

      <div class="flex flex-wrap items-center gap-4 pt-2">
        <a href="/blog" class="px-6 py-3.5 bg-sky-500 hover:bg-sky-600 text-white rounded-2xl font-bold text-sm shadow-md shadow-sky-500/10 hover:shadow-sky-500/20 hover:-translate-y-0.5 transition-all duration-300">
          Read Publications
        </a>
        <a href="#projects" class="px-6 py-3.5 border border-slate-300 dark:border-slate-700 hover:bg-slate-100/50 dark:hover:bg-slate-900/50 text-slate-700 dark:text-slate-300 rounded-2xl font-bold text-sm transition-all duration-300">
          View Projects
        </a>
      </div>
    </div>

    <!-- Right Avatar Space with customized Apple style shadow -->
    <div class="lg:col-span-5 flex justify-center lg:justify-end">
      <div class="relative group max-w-xs md:max-w-sm w-full aspect-square rounded-3xl overflow-hidden border border-slate-200 dark:border-slate-800 shadow-xl shadow-slate-200/50 dark:shadow-none transition-all duration-300">
        <img src="<%= config.avatar %>" alt="<%= config.fullName %>" class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-500" loading="lazy">
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="space-y-8">
    <div class="space-y-2">
      <h2 class="text-xs uppercase font-extrabold tracking-widest text-slate-400 dark:text-slate-500">Overview</h2>
      <h3 class="text-2xl font-bold text-slate-900 dark:text-slate-100">Operational DNA</h3>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Card 1 -->
      <div class="rounded-3xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6 space-y-3 hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
        <h4 class="font-bold text-slate-900 dark:text-slate-100">Who Am I</h4>
        <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
          I am a construction worker and a developer, I enjoy new things and technical subjects like programming and the like. 
        </p>
      </div>

      <!-- Card 2 -->
      <div class="rounded-3xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6 space-y-3 hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
        <h4 class="font-bold text-slate-900 dark:text-slate-100">Occupation</h4>
        <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
          <%= config.occupation %>
        </p>
      </div>

      <!-- Card 3 -->
      <div class="rounded-3xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6 space-y-3 hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
        <h4 class="font-bold text-slate-900 dark:text-slate-100">Hobbies</h4>
        <ul class="text-sm text-slate-600 dark:text-slate-400 space-y-1.5 font-medium">
          <li class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-sky-500"></span>Programming</li>
          <li class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-sky-500"></span>Web Scraping</li>
          <li class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-sky-500"></span>Reading a book</li>
        </ul>
      </div>

      <!-- Card 4 -->
      <div class="rounded-3xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6 space-y-3 hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
        <h4 class="font-bold text-slate-900 dark:text-slate-100">Interests</h4>
        <ul class="text-sm text-slate-600 dark:text-slate-400 space-y-1.5 font-medium">
          <li class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-sky-500"></span>Open Source</li>
          <li class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-sky-500"></span>Backend Development</li>
          <li class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-sky-500"></span>Task Automation</li>
          <li class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-sky-500"></span>Technology</li>
          <li class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-sky-500"></span>Science</li>
          <li class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-sky-500"></span>Physics</li>
          <li class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-sky-500"></span>Psychology</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Project Implementations -->
  <section id="projects" class="space-y-8 scroll-mt-24">
    <div class="space-y-2">
      <h2 class="text-xs uppercase font-extrabold tracking-widest text-slate-400 dark:text-slate-500">Portfolio</h2>
      <h3 class="text-2xl font-bold text-slate-900 dark:text-slate-100">the projects I've created</h3>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% projects.forEach(project => { %>
        <%- include('../partials/project-card', { project }) %>
      <% }) %>
    </div>
  </section>

  <!-- Latest Blog Posts Preview -->
  <section class="space-y-8">
    <div class="flex items-end justify-between border-b border-slate-200/60 dark:border-slate-800/60 pb-4">
      <div class="space-y-2">
        <h2 class="text-xs uppercase font-extrabold tracking-widest text-slate-400 dark:text-slate-500">Writings</h2>
        <h3 class="text-2xl font-bold text-slate-900 dark:text-slate-100">Recent Publications</h3>
      </div>
      <a href="/blog" class="text-sm font-bold text-sky-500 hover:text-sky-600 transition-colors">
        All Publications &rarr;
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% posts.forEach(post => { %>
        <%- include('../partials/post-card', { post }) %>
      <% }) %>
    </div>
  </section>
</div>