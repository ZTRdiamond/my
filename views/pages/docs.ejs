<div class="space-y-12 max-w-4xl mx-auto">
  
  <!-- Title Header -->
  <div class="space-y-3">
    <span class="text-xs font-extrabold uppercase tracking-widest text-slate-400 dark:text-slate-500">Knowledge Base</span>
    <h1 class="text-4xl font-bold tracking-tight text-slate-900 dark:text-slate-100">Technical Documentation</h1>
    <p class="text-slate-600 dark:text-slate-400 max-w-2xl text-base">
      Operational protocols, system architectures, and step-by-step setup checklists.
    </p>
  </div>

  <!-- Document Collection Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <% docs.forEach(doc => { %>
      <div class="group relative rounded-3xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between h-full">
        <div class="space-y-3">
          <div class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-600 dark:text-slate-300">
            <i data-lucide="folder" class="w-5 h-5"></i>
          </div>
          <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 tracking-tight group-hover:text-sky-500 transition-colors duration-300">
            <%= doc.title %>
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed line-clamp-3">
            <%= doc.description %>
          </p>
        </div>
        
        <div class="pt-6 mt-6 border-t border-slate-100 dark:border-slate-800/80">
          <a href="/docs/<%= doc.slug %>" class="inline-flex items-center gap-1.5 text-xs font-bold text-sky-500 hover:text-sky-600 transition-colors">
            <span>Read Documentation</span>
            <i data-lucide="arrow-right" class="w-3.5 h-3.5"></i>
          </a>
        </div>
      </div>
    <% }) %>
  </div>
</div>