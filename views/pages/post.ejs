<article class="max-w-3xl mx-auto space-y-12">
  
  <!-- Breadcrumbs & Nav back link -->
  <div class="pt-4">
    <a href="/blog" class="inline-flex items-center gap-1.5 text-xs font-bold text-slate-500 hover:text-slate-900 dark:hover:text-slate-100 transition-colors">
      <i data-lucide="arrow-left" class="w-4 h-4"></i>
      <span>Back to publications</span>
    </a>
  </div>

  <!-- Header Block -->
  <div class="space-y-6">
    <div class="flex items-center gap-2.5 text-xs font-bold text-slate-400 dark:text-slate-500">
      <time datetime="<%= post.createdAt.toISOString() %>">
        <%= post.createdAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
      </time>
      <span>&bull;</span>
      <span><%= post.readingTime %></span>
    </div>

    <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-slate-100 tracking-tight leading-tight">
      <%= post.title %>
    </h1>

    <div class="flex flex-wrap gap-2">
      <% post.tags.forEach(tag => { %>
        <span class="text-xs font-bold px-3 py-1 border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 text-slate-600 dark:text-slate-300 rounded-full">
          #<%= tag %>
        </span>
      <% }) %>
    </div>
  </div>

  <!-- Hero Image -->
  <% if (post.cover) { %>
    <div class="rounded-3xl overflow-hidden border border-slate-200 dark:border-slate-800 bg-slate-100 dark:bg-slate-950 aspect-[21/9]">
      <img src="<%= post.cover %>" alt="<%= post.title %>" class="w-full h-full object-cover" loading="lazy">
    </div>
  <% } %>

  <!-- Standard Prose Block configured with Tailwind Typography and custom dark styles -->
  <div class="prose prose-slate dark:prose-invert max-w-none leading-relaxed text-slate-800 dark:text-slate-200
    prose-headings:font-bold prose-headings:tracking-tight
    prose-h2:text-2xl prose-h2:border-b prose-h2:border-slate-100 dark:prose-h2:border-slate-850 prose-h2:pb-2
    prose-a:text-sky-500 prose-a:no-underline hover:prose-a:underline
    prose-blockquote:border-l-4 prose-blockquote:border-sky-500 prose-blockquote:bg-slate-50 dark:prose-blockquote:bg-slate-900 prose-blockquote:p-4 prose-blockquote:rounded-r-2xl prose-blockquote:not-italic">
    <%- post.html %>
  </div>
</article>