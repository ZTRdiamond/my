<div class="max-w-4xl mx-auto space-y-12">
  
  <!-- Return Selector Link -->
  <div class="pt-4">
    <a href="/docs" class="inline-flex items-center gap-1.5 text-xs font-bold text-slate-500 hover:text-slate-900 dark:hover:text-slate-100 transition-colors">
      <i data-lucide="arrow-left" class="w-4 h-4"></i>
      <span>Back to documentation</span>
    </a>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
    
    <!-- Left Column: Primary documentation output -->
    <article class="lg:col-span-8 space-y-6">
      <div class="border-b border-slate-200 dark:border-slate-800 pb-6 space-y-3">
        <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 dark:text-slate-100 tracking-tight">
          <%= doc.title %>
        </h1>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">
          <%= doc.description %>
        </p>
      </div>

      <!-- Markdown HTML Area -->
      <div class="prose prose-slate dark:prose-invert max-w-none leading-relaxed text-slate-850 dark:text-slate-200
        prose-headings:font-bold prose-headings:tracking-tight
        prose-h2:text-2xl prose-h2:pb-1 prose-h2:border-b prose-h2:border-slate-150 dark:prose-h2:border-slate-800
        prose-a:text-sky-500 prose-a:no-underline hover:prose-a:underline">
        <%- doc.html %>
      </div>
    </article>

    <!-- Right Column: Sticky Navigation Context -->
    <aside class="hidden lg:block lg:col-span-4 sticky top-24">
      <div class="rounded-3xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6 space-y-4">
        <div class="flex items-center gap-2 text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider">
          <i data-lucide="book-open" class="w-4 h-4"></i>
          <span>Document Index</span>
        </div>
        <div class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed space-y-2">
          <p>This reference architecture was compiled during system build. Check back frequently for updates.</p>
        </div>
      </div>
    </aside>
    
  </div>
</div>